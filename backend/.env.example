# Keep this false while learning/testing.
LIVE_TRADING_ENABLED=false

# Optional. If set, POST requests must include this value in the X-API-Key header.
API_SECRET=change-me

# Optional MT5 login fields. You can also log in manually in the MT5 terminal instead.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# CORS: for GitHub Pages, set this to your page URL later, e.g. https://username.github.io/shado-mt5-webbot
ALLOWED_ORIGINS=*
